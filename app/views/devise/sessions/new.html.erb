<div class="min-h-screen flex items-center justify-center bg-gray-900">

  <div class="bg-gray-800 p-10 rounded-2xl shadow-2xl w-full max-w-md">

    <h2 class="text-3xl font-bold text-center text-blue-400 mb-8">
      Login 🚀
    </h2>

    <%= form_for(resource, as: resource_name,
                 url: session_path(resource_name)) do |f| %>

      <!-- Email -->
      <div class="mb-5">
        <%= f.label :email, class: "block mb-2 text-gray-300" %>
        <%= f.email_field :email,
                          autofocus: true,
                          class: "w-full px-4 py-2 rounded-lg bg-gray-700 text-white focus:outline-none focus:ring-2 focus:ring-blue-500" %>
      </div>

      <!-- Password -->
      <div class="mb-5">
        <%= f.label :password, class: "block mb-2 text-gray-300" %>
        <%= f.password_field :password,
                             class: "w-full px-4 py-2 rounded-lg bg-gray-700 text-white focus:outline-none focus:ring-2 focus:ring-blue-500" %>
      </div>

      <!-- Remember -->
      <div class="flex items-center mb-6">
        <%= f.check_box :remember_me, class: "mr-2" %>
        <%= f.label :remember_me, class: "text-gray-400 text-sm" %>
      </div>

      <!-- Botão -->
      <div>
        <%= f.submit "Entrar",
                     class: "w-full bg-blue-500 hover:bg-blue-600 transition px-4 py-2 rounded-lg font-semibold text-white" %>
      </div>

    <% end %>

    <!-- Esqueci senha -->
    <div class="mt-6 text-center">
      <%= link_to "Esqueceu sua senha?",
                  new_password_path(resource_name),
                  class: "text-sm text-gray-400 hover:text-blue-400 transition" %>
    </div>

  </div>

</div>