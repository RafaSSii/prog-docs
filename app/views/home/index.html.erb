<div class="min-h-screen bg-gray-900 text-white flex flex-col items-center justify-center">
  <h1 class="text-5xl font-bold mb-6 text-blue-400">
    ProgDocs 🚀
  </h1>

  <p class="text-lg text-gray-300 mb-8 text-center max-w-xl">
    Plataforma para organizar e acessar documentações de linguagens de programação.
  </p>

  <% if user_signed_in? %>
    <div class="flex gap-4">
      <%= link_to "Painel Admin", admin_languages_path,
                  class: "bg-blue-500 hover:bg-blue-600 px-6 py-3 rounded-xl font-semibold transition" %>
    </div>
  <% end %>
</div>