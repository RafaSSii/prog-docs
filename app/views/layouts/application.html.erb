<!DOCTYPE html>
<html>
<head>
  <title>ProgDocs</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>

<body class="bg-gray-900 text-white">

<!-- NAVBAR -->
<nav class="bg-gray-800 shadow-lg">
  <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">

    <!-- Logo -->
    <%= link_to "ProgDocs 🚀", root_path,
                class: "text-2xl font-bold text-blue-400 hover:text-blue-300 transition" %>

    <!-- Links -->
    <div class="flex gap-6 items-center">

      <%= link_to "Home", root_path,
                  class: "hover:text-blue-400 transition" %>

      <%= link_to "Linguagens", languages_path,
                  class: "hover:text-blue-400 transition" %>

      <% if user_signed_in? %>

        <%= link_to "Logout", destroy_user_session_path,
                    data: { turbo_method: :delete },
                    class: "bg-red-500 hover:bg-red-600 px-4 py-2 rounded-lg font-semibold transition" %>

        <%= link_to "Nova Linguagem",
                    new_admin_language_path,
                    class: "bg-blue-500 hover:bg-blue-600 px-4 py-2 rounded-lg font-semibold transition" %>

      <% else %>

        <%= link_to "Login", new_user_session_path,
                    class: "bg-blue-500 hover:bg-blue-600 px-4 py-2 rounded-lg font-semibold transition" %>

      <% end %>

    </div>

  </div>
</nav>

<!-- Conteúdo da página -->
<main class="container mx-auto px-6 py-10">
  <%= yield %>
</main>

</body>
</html>