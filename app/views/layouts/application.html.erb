<!DOCTYPE html>
<html>
<head>
  <title>ProgDocs</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>

<body class="bg-gray-900 text-white">

<!-- NAVBAR -->
<nav class="bg-gray-800 shadow-lg">
  <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">

    <!-- Logo -->
    <%= link_to "ProgDocs 🚀", root_path, class: "text-2xl font-bold text-blue-400 hover:text-blue-300 transition" %>

    <!-- Links -->
    <div class="flex gap-6 items-center">
      <%= link_to "Home", root_path, class: "hover:text-blue-400 transition" %>
      <%= link_to "Linguagens", "#", class: "hover:text-blue-400 transition" %>
      <%= link_to "Nova Linguagem", "#", class: "bg-blue-500 hover:bg-blue-600 px-4 py-2 rounded-lg font-semibold transition" %>
    </div>

  </div>
</nav>

<!-- Conteúdo da página -->
<main class="container mx-auto px-6 py-10">
  <%= yield %>
</main>

</body>
</html>